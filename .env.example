# ============================================================
# .env.example — Lunar Thermal Hazard
# Copy this file to .env and fill in your credentials.
# Never commit the real .env to version control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Your Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=

# Your Supabase anon or service-role key (Settings → API → Project API Keys)
SUPABASE_KEY=

# ── PostgreSQL (direct connection via SQLAlchemy) ─────────────
# Used by the backend graph builder and worker for raw SQL.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require
# Found in Supabase → Settings → Database → Connection string
DATABASE_URL=

# ── GNN Model ────────────────────────────────────────────────
# Absolute path to the trained GraphSAGE model inside the container.
# Do not change this unless you move the .pth file.
MODEL_PATH=/app/lunagraph_gcn_model.pth

# ── Frontend (Vite build-time variables) ─────────────────────
# These are injected into the React bundle at build time.
# Must match your Supabase project credentials.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Server port ───────────────────────────────────────────────
# Port exposed by the FastAPI backend (default: 8000).
PORT=8000

# ── Python runtime ────────────────────────────────────────────
# Disables output buffering so Docker sees logs immediately.
PYTHONUNBUFFERED=1

# ── Worker schedule (optional — defaults shown) ───────────────
# Frequency of each background job, in hours.
NOAA_FETCH_INTERVAL_HOURS=6
DATASET_INTERVAL_HOURS=24
INFERENCE_INTERVAL_HOURS=6
